{
  "name": "shiba-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo UI library for React.js and React Native",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:shared": "npm run build --workspace=@shiba-ui/shared",
    "build:browser": "npm run build --workspace=@shiba-ui/browser",
    "build:mobile": "npm run build --workspace=@shiba-ui/mobile",
    "start": "storybook dev -p 8008 -c ./.storybook/config",
    "build-storybook": "storybook build",
    "storybook": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/addon-react-native-web": "^0.0.29",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.1",
    "@storybook/react-webpack5": "^9.1.13",
    "babel-loader": "^10.0.0",
    "react-dom": "^19.2.0",
    "react-native-web": "^0.21.2",
    "storybook": "^9.1.13",
    "ts-loader": "^9.5.4",
    "tty-browserify": "^0.0.1",
    "typescript": "^5.7.2"
  }
}
